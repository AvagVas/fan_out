{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Console": {
      "IncludeScopes": true
    }
  },
  "AllowedHosts": "*",
  "ServiceB": {
    "GroupId": "service-b",
    "MaxAttempts": 3,
    "RetryDelayMs": 200
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "SchemaRegistryUrl": "http://localhost:8081",
    "Topics": {
      "ProxyRequests": "proxy.requests",
      "ServiceACompleted": "service-a.completed",
      "ServiceBReady": "service-b.ready",
      "ServiceBDlq": "service-b.dlq"
    }
  }
}
