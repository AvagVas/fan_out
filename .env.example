# Copy to .env and fill in for Confluent Cloud (or any secured cluster).
# These flat variables override appsettings.json at runtime (see KafkaOptions.ApplyEnvironmentOverrides).

# Which Enricher implementation to run: "manual" (custom KTable-KTable) or "streamiz" (Streamiz DSL).
# Compose reads COMPOSE_PROFILES from .env; run only one at a time.
COMPOSE_PROFILES=manual

BOOTSTRAP_SERVERS=pkc-xxxxx.region.provider.confluent.cloud:9092
SCHEMA_REGISTRY_URL=https://psrc-xxxxx.region.provider.confluent.cloud

# Cluster SASL credentials (presence of SASL_USERNAME switches clients to SASL_SSL/PLAIN).
SASL_USERNAME=
SASL_PASSWORD=

# Schema Registry basic-auth (API key/secret).
SCHEMA_REGISTRY_API_KEY=
SCHEMA_REGISTRY_API_SECRET=

# Optional: OpenTelemetry OTLP collector endpoint (enables OTLP trace/metric export).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
